{
  "name": "gis-vols-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "GIS · ВОЛС — клиент для Windows (Electron)",
  "author": "GIS VOLS",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"npm run dev\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:127.0.0.1:5173 && cross-env GIS_DESKTOP_DEV=1 GIS_START_LOCAL_BACKEND=1 FRONTEND_URL=http://127.0.0.1:5173 electron .",
    "electron:dist": "cross-env GIS_LOAD_DIST=1 GIS_START_LOCAL_BACKEND=0 electron .",
    "electron": "electron .",
    "build": "tsc -b && vite build",
    "build:desktop": "cross-env ELECTRON_BUILD=1 CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "build:desktop:dir": "cross-env ELECTRON_BUILD=1 CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir",
    "build:desktop:zip": "cross-env ELECTRON_BUILD=1 CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win zip",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "supercluster": "^8.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supercluster": "^7.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "ru.gis.vols",
    "productName": "GIS VOLS",
    "copyright": "GIS VOLS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/gis-desktop.json.example",
        "to": "gis-desktop.json.example"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "GIS-VOLS-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GIS VOLS"
    }
  }
}
